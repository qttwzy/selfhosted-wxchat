NODE_ENV=production
HOST=0.0.0.0
PORT=3000

PUBLIC_BASE_URL=https://your-domain

DATABASE_PATH=/app/data/wxchat.db
UPLOAD_DIR=/app/uploads

ACCESS_PASSWORD=change-me
JWT_SECRET=change-me-long-random-string
SESSION_EXPIRE_HOURS=24
MAX_FILE_SIZE_MB=100
MESSAGE_DEVICE_INFO_ENABLED=false
MESSAGE_GROUP_WINDOW_MINUTES=15
APP_TIMEZONE=
ALLOW_CLIENT_TIMEZONE_OVERRIDE=true

AI_ENABLED=false
AI_CHAT_BASE_URL=https://api.example.com/v1/chat/completions
AI_CHAT_API_KEY=
AI_CHAT_MODEL=
AI_CHAT_MAX_TOKENS=4000
AI_CHAT_TEMPERATURE=0.7
AI_RATE_LIMIT=10

IMAGE_GEN_ENABLED=false
AI_IMAGE_BASE_URL=https://api.example.com/v1/images/generations
AI_IMAGE_API_KEY=
AI_IMAGE_MODEL=
AI_IMAGE_DEFAULT_SIZE=1024x1024
AI_IMAGE_DEFAULT_STEPS=20
AI_IMAGE_DEFAULT_GUIDANCE=7.5
AI_IMAGE_MAX_PROMPT_LENGTH=1000
IMAGE_RATE_LIMIT=5
